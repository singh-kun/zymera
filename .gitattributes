# Normalise line endings to LF in the repo; check out as-is on all platforms.
* text=auto eol=lf
*.py text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binaries — never diff or normalise
*.png binary
*.jpg binary
*.mp4 binary
*.wav binary
*.bin binary
*.safetensors binary
*.onnx binary
